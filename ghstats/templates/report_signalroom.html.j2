{% extends "report_base.html.j2" %}

{% block theme_css %}
<style>

/* Signal Room Theme */
.template-signalroom {
  background: #0a0a0a;
  color: #d0d0d0;
  font-family: 'IBM Plex Mono', monospace;
}
.template-signalroom .hero {
  background: #111;
  border: 2px solid #333;
  border-radius: 0;
  border-top: 8px solid #9ff5a4;
}
.template-signalroom h1, .template-signalroom h2, .template-signalroom .section-kicker {
  color: #9ff5a4;
  text-shadow: 0 0 8px rgba(159,245,164,0.4);
}
.template-signalroom .panel, .template-signalroom .chart-card {
  background: #141414;
  border: 1px solid #333;
  border-radius: 0;
}
.template-signalroom .repo-card, .template-signalroom .fact, .template-signalroom .hero-stat {
  background: #000;
  border: 1px solid #444;
  border-radius: 0;
}
.template-signalroom .chip {
  background: #222;
  border: 1px solid #555;
  color: #f2b15d;
}

</style>
{% endblock %}
