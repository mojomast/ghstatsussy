{% extends "report_base.html.j2" %}

{% block hero %}
<style>
/* Subway Map Theme */
.transit-hero {
  background: #111;
  color: #eee;
  padding: 60px 40px;
  border-bottom: 8px solid #ff4500;
  position: relative;
  overflow: hidden;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
.transit-line {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 12px;
  background: #0078d7;
  z-index: 0;
  transform: translateY(-50%);
}
.transit-line-2 {
  position: absolute;
  top: 70%;
  left: -10%;
  right: -10%;
  height: 12px;
  background: #ffcc00;
  z-index: 0;
  transform: rotate(-5deg);
}
.transit-station {
  position: relative;
  z-index: 1;
  background: #111;
  border: 6px solid #ff4500;
  border-radius: 50%;
  width: 140px;
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30px;
}
.transit-avatar {
  border-radius: 50%;
  width: 110px;
  height: 110px;
  object-fit: cover;
}
.transit-title {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 4rem;
  font-weight: 800;
  letter-spacing: -1px;
  text-transform: uppercase;
  margin-bottom: 10px;
  text-shadow: 3px 3px 0 #000;
}
.transit-subtitle {
  position: relative;
  z-index: 1;
  text-align: center;
  font-size: 1.2rem;
  color: #aaa;
  background: #222;
  display: inline-block;
  padding: 5px 15px;
  border-radius: 20px;
  margin: 0 auto;
  display: block;
  width: fit-content;
}
.transit-stats {
  position: relative;
  z-index: 1;
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 40px;
}
.transit-stat-box {
  background: #222;
  border-left: 8px solid #00ce00;
  padding: 15px 25px;
  color: #fff;
}
.transit-stat-box .value {
  font-size: 2rem;
  font-weight: bold;
}
.transit-stat-box .label {
  font-size: 0.8rem;
  text-transform: uppercase;
  color: #888;
}
</style>

<div class="transit-hero">
  <div class="transit-line"></div>
  <div class="transit-line-2"></div>
  
  <div class="transit-station">
    {% if context.meta.subject.avatar_url %}
    <img class="transit-avatar" src="{{ context.meta.subject.avatar_url }}" alt="avatar" />
    {% endif %}
  </div>
  
  <h1 class="transit-title">{{ context.meta.subject.login }} STATION</h1>
  <div class="transit-subtitle">{{ context.meta.period.start }} TO {{ context.meta.period.end }}</div>

  <div class="transit-stats">
    {% for card in context.stats_cards[:4] %}
    <div class="transit-stat-box" style="border-color: {% if loop.index0 == 0 %}#ff4500{% elif loop.index0 == 1 %}#0078d7{% elif loop.index0 == 2 %}#ffcc00{% else %}#00ce00{% endif %};">
      <div class="value">{{ card.value }}</div>
      <div class="label">{{ card.label }}</div>
    </div>
    {% endfor %}
  </div>
</div>
{% endblock %}

{% block content %}
<style>
.transit-content {
  background: #1a1a1a;
  color: #ddd;
  padding: 50px;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}
.transit-map {
  display: flex;
  flex-direction: column;
  gap: 40px;
}
.transit-route {
  background: #222;
  border-radius: 10px;
  padding: 30px;
  position: relative;
  overflow: hidden;
}
.transit-route::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 15px;
  background: var(--route-color, #ff4500);
}
.transit-route h2 {
  margin-top: 0;
  font-size: 2rem;
  text-transform: uppercase;
  margin-bottom: 20px;
  color: #fff;
}
.transit-stops {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}
.transit-stop {
  background: #333;
  padding: 15px;
  border-radius: 8px;
  flex: 1;
  min-width: 250px;
  border: 2px solid #444;
}
.transit-stop h3 {
  margin: 0 0 10px 0;
  color: #fff;
}
.transit-stop p {
  margin: 0;
  color: #bbb;
  font-size: 0.9rem;
}
</style>

<div class="transit-content">
  <div class="transit-map">
    
    <div class="transit-route" style="--route-color: #0078d7;">
      <h2>Activity Line (Commits)</h2>
      <div style="height: 300px; width: 100%; background: #111; padding: 20px; border-radius: 8px;">
        <canvas id="commitsChart"></canvas>
      </div>
    </div>

    <div class="transit-route" style="--route-color: #ffcc00;">
      <h2>Language Terminals</h2>
      <div style="height: 300px; width: 100%; background: #111; padding: 20px; border-radius: 8px;">
        <canvas id="languageChart"></canvas>
      </div>
      <div style="margin-top: 20px; display: flex; gap: 10px; flex-wrap: wrap;">
        {% for lang in context.language_slices %}
        <span style="background: #333; padding: 5px 10px; border-radius: 20px; font-size: 0.8rem; border: 1px solid #555;">{{ lang.name }} ({{ lang.percent }}%)</span>
        {% endfor %}
      </div>
    </div>

    <div class="transit-route" style="--route-color: #00ce00;">
      <h2>Key Destinations (Repositories)</h2>
      <div class="transit-stops">
        {% for repo in context.repo_insights %}
        <div class="transit-stop">
          <h3>{{ repo.full_name }}</h3>
          <p>{{ repo.description or 'No description' }}</p>
          <div style="margin-top: 10px; display: flex; gap: 5px;">
            <span style="background: #111; padding: 3px 8px; border-radius: 4px; font-size: 0.7rem;">★ {{ repo.stars }}</span>
            <span style="background: #111; padding: 3px 8px; border-radius: 4px; font-size: 0.7rem;">⑂ {{ repo.forks }}</span>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>

  </div>
</div>
{% endblock %}