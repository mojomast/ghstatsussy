{% extends "report_base.html.j2" %}

{% block theme_css %}
<style>
/* Subway Map Theme applied to Canonical DOM */
.template-transit {
  background: #1a1a1a;
  color: #ddd;
  font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
}

/* Hero Map Lines */
.template-transit .hero {
  background: #111;
  color: #eee;
  padding: 60px 40px;
  border: none;
  border-bottom: 8px solid #ff4500;
  border-radius: 0;
  position: relative;
  overflow: hidden;
}

.template-transit .hero::before {
  content: "";
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 12px;
  background: #0078d7;
  z-index: 0;
  transform: translateY(-50%);
}

.template-transit .hero::after {
  content: "";
  position: absolute;
  top: 70%;
  left: -10%;
  right: -10%;
  height: 12px;
  background: #ffcc00;
  z-index: 0;
  transform: rotate(-5deg);
}

.template-transit .hero-copy,
.template-transit .hero-side {
  position: relative;
  z-index: 1;
}

/* Make it look more centered like transit */
.template-transit .hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

/* Station Avatar */
.template-transit .profile-card {
  background: #111;
  border: 6px solid #ff4500;
  border-radius: 50%;
  width: 140px;
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 30px;
  padding: 0;
}

.template-transit .profile-card img {
  border-radius: 50%;
  width: 110px;
  height: 110px;
  object-fit: cover;
}

/* Hide extra text in profile card to make it just a station */
.template-transit .profile-card div {
  display: none;
}

.template-transit .hero h1 {
  font-size: 4rem;
  font-weight: 800;
  letter-spacing: -1px;
  text-transform: uppercase;
  margin-bottom: 10px;
  text-shadow: 3px 3px 0 #000;
}

.template-transit .chip {
  background: #222;
  border: none;
  border-radius: 20px;
  color: #aaa;
}

/* Stat boxes */
.template-transit .hero-stat {
  background: #222;
  border: none;
  border-left: 8px solid #00ce00;
  border-radius: 0;
  padding: 15px 25px;
  color: #fff;
  box-shadow: none;
}

.template-transit .hero-stat:nth-child(1) { border-left-color: #ff4500; }
.template-transit .hero-stat:nth-child(2) { border-left-color: #0078d7; }
.template-transit .hero-stat:nth-child(3) { border-left-color: #ffcc00; }
.template-transit .hero-stat:nth-child(4) { border-left-color: #00ce00; }

/* Route Panels */
.template-transit .panel,
.template-transit .chart-card {
  background: #222;
  border: none;
  border-radius: 10px;
  padding: 30px;
  position: relative;
  overflow: hidden;
  box-shadow: none;
}

.template-transit .panel::before,
.template-transit .chart-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; bottom: 0;
  width: 15px;
  background: #0078d7; /* Default route line */
}

/* Color different sections */
.template-transit .charts-grid .chart-card:nth-child(1)::before { background: #0078d7; }
.template-transit .charts-grid .chart-card:nth-child(2)::before { background: #ffcc00; }
.template-transit .panel::before { background: #00ce00; }

.template-transit h2 {
  font-size: 2rem;
  text-transform: uppercase;
  color: #fff;
}

/* Stops (Repos and facts) */
.template-transit .repo-card,
.template-transit .fact {
  background: #222;
  border: none;
  border-left: 8px solid #ff4500;
  border-radius: 0;
  padding: 15px;
}

.template-transit .fact { border-left-color: #0078d7; }

.template-transit .repo-card .chip {
  background: #111;
  padding: 3px 8px;
  font-size: 0.7rem;
  border-radius: 4px;
}

.template-transit .warning {
  background: #331111;
  border-left: 8px solid #ff0000;
  border-radius: 0;
}

.template-transit .language-item {
  border-left: 4px solid #ffcc00;
  background: #111;
  border-radius: 0;
}

</style>
{% endblock %}
