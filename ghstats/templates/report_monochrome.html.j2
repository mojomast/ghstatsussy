{% extends "report_base.html.j2" %}
{% block theme_css %}
<style>
  :root {
    --ink: #000; --muted: #555;
  }
  body {
    background: #fff;
    color: #000;
    font-family: 'Courier New', Courier, monospace;
    background-image: linear-gradient(45deg, #000 25%, transparent 25%, transparent 75%, #000 75%, #000), linear-gradient(45deg, #000 25%, transparent 25%, transparent 75%, #000 75%, #000);
    background-size: 20px 20px;
    background-position: 0 0, 10px 10px;
    padding: 20px;
  }
  .shell {
    background: #fff;
    border: 12px solid #000;
    padding: 40px;
    max-width: 1200px;
    margin: 0 auto;
    box-shadow: 15px 15px 0 #fff, 15px 15px 0 4px #000;
  }
  .main-content {
    column-count: 2;
    column-gap: 40px;
    column-rule: 4px solid #000;
  }
  .hero, .panel, .chart-card, .stat-card, .repo-card, .fact, .warning, .mini-panel, .profile-card, .hero-stat {
    background: #fff !important;
    border: 4px solid #000 !important;
    border-radius: 0 !important;
    box-shadow: 8px 8px 0 #000;
    transition: all 0.2s ease-in-out;
    color: #000 !important;
    margin-bottom: 24px;
    break-inside: avoid;
  }
  .panel:hover, .chart-card:hover, .repo-card:hover, .stat-card:hover {
    background: #000 !important;
    color: #fff !important;
    transform: translate(-4px, -4px);
    box-shadow: 12px 12px 0 #fff, 14px 14px 0 2px #000;
  }
  .panel:hover *, .chart-card:hover *, .repo-card:hover *, .stat-card:hover * {
    color: #fff !important;
    border-color: #fff !important;
  }
  h1 { font-size: 4rem; text-transform: uppercase; border-bottom: 8px solid #000; padding-bottom: 10px; letter-spacing: -2px; }
  h1, h2, h3, .value, p { color: inherit !important; font-family: 'Impact', 'Arial Black', sans-serif; }
  .muted { font-style: italic; opacity: 0.8; }
  .chip, .eyebrow {
    border-radius: 0;
    border: 2px solid currentColor;
    background: transparent;
    color: inherit;
    text-transform: uppercase;
    font-weight: 900;
    letter-spacing: 2px;
  }
  .hero {
    border-bottom: 12px double #000 !important;
    margin-bottom: 40px;
    padding: 20px;
    background: repeating-linear-gradient(45deg, #fff, #fff 10px, #000 10px, #000 12px) !important;
  }
  .hero > * { background: #fff; padding: 5px; border: 2px solid #000; display: inline-block; }
  canvas { filter: grayscale(100%) contrast(200%); mix-blend-mode: multiply; }
  .panel:hover canvas, .chart-card:hover canvas { filter: invert(1) grayscale(100%) contrast(200%); mix-blend-mode: screen; }
</style>
{% endblock %}
