{% extends "report_base.html.j2" %}

{% block theme_css %}
<style>

/* Tape Archive Theme */
.template-tapearchive {
  background: #2b2b2b;
  color: #e0e0e0;
}
.template-tapearchive .hero, .template-tapearchive .panel, .template-tapearchive .chart-card {
  background: #1e1e1e;
  border: 2px solid #444;
  border-radius: 8px;
  box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
}
.template-tapearchive .hero {
  border-top: 16px solid #ffb100;
}
.template-tapearchive .section-kicker {
  background: #ffb100;
  color: #000;
  padding: 2px 8px;
  border-radius: 2px;
  font-family: monospace;
  font-weight: bold;
}
.template-tapearchive .repo-card, .template-tapearchive .fact, .template-tapearchive .hero-stat {
  background: #333;
  border: 1px solid #555;
  border-radius: 4px;
  box-shadow: 0 4px 0 #111;
}
.template-tapearchive .chip {
  background: #00a6a6;
  color: #fff;
  border: none;
  border-radius: 2px;
}

</style>
{% endblock %}
