{% extends "report_base.html.j2" %}

{% block hero %}
<style>
.tape-hero {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: #111;
    padding: 20px;
    border-radius: 12px;
}
.tape-strip {
    display: flex;
    background: linear-gradient(90deg, #2a2a2a, #333);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.5);
    border: 1px solid #444;
}
.tape-reel {
    width: 100px;
    background: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 2px solid #000;
}
.tape-reel-inner {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    border: 4px dashed #666;
    animation: spin 10s linear infinite;
}
.tape-content {
    flex: 1;
    padding: 20px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.tape-title {
    font-size: 2.5rem;
    margin: 0;
    color: #e0e0e0;
    font-family: 'Arial Black', sans-serif;
    letter-spacing: -1px;
}
.tape-meta {
    color: #888;
    font-size: 0.9rem;
    text-transform: uppercase;
}
.tape-stat-group {
    display: flex;
    gap: 30px;
}
.tape-stat {
    text-align: right;
}
.tape-stat-val {
    font-size: 2rem;
    color: #f39c12;
    font-weight: bold;
    font-family: monospace;
}
.tape-stat-label {
    font-size: 0.7rem;
    color: #aaa;
    letter-spacing: 1px;
}
@keyframes spin { 100% { transform: rotate(360deg); } }
</style>

<div class="tape-hero">
    <div class="tape-strip">
        <div class="tape-reel"><div class="tape-reel-inner"></div></div>
        <div class="tape-content">
            <div>
                <div class="tape-meta">ARCHIVE ID: @{{ context.meta.subject.login }} // {{ context.meta.period.start }} - {{ context.meta.period.end }}</div>
                <h1 class="tape-title">MASTER RECORD</h1>
            </div>
            <div class="tape-stat-group">
                {% for card in context.stats_cards[:3] %}
                <div class="tape-stat">
                    <div class="tape-stat-val">{{ card.value }}</div>
                    <div class="tape-stat-label">{{ card.label }}</div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block content %}
<style>
.tape-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 15px;
    margin-top: 20px;
}
.tape-module {
    background: #222;
    border-radius: 8px;
    border: 1px solid #333;
    padding: 25px;
    position: relative;
    overflow: hidden;
}
.tape-module::before {
    content: '';
    position: absolute;
    top: 0; bottom: 0; left: 0;
    width: 10px;
    background: repeating-linear-gradient(45deg, #f39c12, #f39c12 10px, #222 10px, #222 20px);
}
.tape-module-title {
    color: #f39c12;
    margin: 0 0 20px 15px;
    font-family: monospace;
    font-size: 1.2rem;
    letter-spacing: 2px;
}
.tape-chart-wrapper {
    margin-left: 15px;
    height: 250px;
}
.tape-highlights {
    margin-left: 15px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 15px;
}
.tape-highlight-item {
    background: #1a1a1a;
    padding: 15px;
    border: 1px solid #444;
    border-radius: 4px;
}
.tape-highlight-item h3 {
    margin: 0 0 5px;
    color: #ddd;
    font-size: 1.1rem;
}
.tape-highlight-item p {
    color: #888;
    margin: 0;
    font-size: 0.9rem;
}
</style>

<div class="tape-grid">
    <div class="tape-module">
        <h2 class="tape-module-title">MODULE 1 // TIMELINE_ANALYSIS</h2>
        <div class="tape-chart-wrapper">
            <canvas id="commitsChart"></canvas>
        </div>
    </div>
    
    <div class="tape-module">
        <h2 class="tape-module-title">MODULE 2 // EVENT_LOGS</h2>
        <div class="tape-highlights">
            {% for item in context.highlights %}
            <div class="tape-highlight-item">
                <h3>{{ item.title }} {% if item.value %}<span style="color:#f39c12">[{{ item.value }}]</span>{% endif %}</h3>
                <p>{{ item.text }}</p>
            </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
