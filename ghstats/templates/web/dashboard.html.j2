<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard - ghstatsussy hosted</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg-0: #09111d;
        --bg-1: #0d1727;
        --panel: rgba(10, 17, 30, 0.82);
        --panel-strong: rgba(9, 15, 26, 0.94);
        --line: rgba(142, 194, 255, 0.13);
        --line-strong: rgba(142, 194, 255, 0.28);
        --ink: #ebf4ff;
        --muted: #8fa4bb;
        --cyan: #5ad8ff;
        --lime: #9ff5a4;
        --amber: #f2b15d;
        --coral: #ff8573;
        --shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
        --radius-xl: 28px;
        --radius-lg: 20px;
        --radius-md: 14px;
      }

      * {
        box-sizing: border-box;
      }

      [hidden] {
        display: none !important;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "IBM Plex Sans", sans-serif;
        color: var(--ink);
        color-scheme: dark;
        background:
          radial-gradient(circle at top left, rgba(90, 216, 255, 0.14), transparent 24%),
          radial-gradient(circle at top right, rgba(159, 245, 164, 0.08), transparent 20%),
          linear-gradient(160deg, #07101a 0%, #0b1420 50%, #0f1728 100%);
        position: relative;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px);
        background-size: 34px 34px;
        pointer-events: none;
      }

      .shell {
        width: min(1240px, calc(100% - 28px));
        margin: 24px auto 38px;
        position: relative;
        z-index: 1;
      }

      .topbar,
      .panel,
      .status-strip {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .topbar {
        padding: 20px 24px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
      }

      .profile {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .profile img {
        width: 66px;
        height: 66px;
        border-radius: 18px;
        border: 1px solid var(--line);
      }

      .eyebrow,
      .micro,
      .chip,
      label,
      .button-text,
      .step-label {
        font-family: "IBM Plex Mono", monospace;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      .muted {
        color: var(--muted);
      }

      .logout,
      .primary,
      .secondary,
      .text-link {
        appearance: none;
        border: 0;
        text-decoration: none;
        cursor: pointer;
        font: inherit;
      }

      .logout,
      .secondary {
        padding: 12px 16px;
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.06);
        color: var(--ink);
      }

      .primary {
        padding: 14px 18px;
        border-radius: 16px;
        background: linear-gradient(135deg, var(--cyan), var(--lime));
        color: #06111c;
        font-weight: 700;
      }

      .layout {
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 24px;
        margin-top: 24px;
        align-items: start;
      }

      .panel {
        padding: 24px;
        position: relative;
        overflow: hidden;
      }

      .panel::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(90, 216, 255, 0.06), transparent 42%);
        pointer-events: none;
      }

      .eyebrow {
        display: inline-flex;
        width: fit-content;
        padding: 8px 10px;
        border-radius: 999px;
        border: 1px solid rgba(90, 216, 255, 0.24);
        color: var(--cyan);
        font-size: 11px;
      }

      .stack {
        display: grid;
        gap: 18px;
      }

      .field {
        display: grid;
        gap: 8px;
        margin-top: 14px;
      }

      label {
        font-size: 11px;
        color: var(--muted);
      }

      input,
      select {
        appearance: none;
        -webkit-appearance: none;
        width: 100%;
        border: 1px solid rgba(142, 194, 255, 0.22);
        background: #101826;
        color: var(--ink);
        border-radius: 14px;
        padding: 13px 14px;
        font: inherit;
        box-shadow: none;
      }

      input::placeholder {
        color: #a7b7cb;
        opacity: 1;
      }

      input:hover,
      select:hover {
        background: #142031;
      }

      input:focus,
      select:focus {
        outline: none;
        border-color: rgba(90, 216, 255, 0.82);
        box-shadow: 0 0 0 4px rgba(90, 216, 255, 0.16);
      }

      select,
      option,
      optgroup {
        color: var(--ink);
        background: #101826;
      }

      select {
        padding-right: 42px;
        background-image:
          linear-gradient(45deg, transparent 50%, #a7b7cb 50%),
          linear-gradient(135deg, #a7b7cb 50%, transparent 50%);
        background-position:
          calc(100% - 18px) calc(50% - 3px),
          calc(100% - 12px) calc(50% - 3px);
        background-size: 6px 6px, 6px 6px;
        background-repeat: no-repeat;
      }

      input[type="checkbox"] {
        width: auto;
        accent-color: var(--cyan);
      }

      .checkbox-row {
        display: flex;
        align-items: flex-start;
        gap: 10px;
        padding: 12px 14px;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
      }

      .form-error {
        margin-top: 14px;
        padding: 13px 14px;
        border-radius: 14px;
        border: 1px solid rgba(255, 133, 115, 0.32);
        background: rgba(255, 133, 115, 0.1);
        color: #ffd2cb;
      }

      .field-hint {
        margin-top: 8px;
        font-size: 0.92rem;
      }

      .template-picker {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
        margin-top: 8px;
      }

      .template-option {
        position: relative;
      }

      .template-option input {
        position: absolute;
        opacity: 0;
        pointer-events: none;
      }

      .template-card {
        display: grid;
        gap: 10px;
        min-height: 156px;
        padding: 14px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
        cursor: pointer;
        transition: transform 140ms ease, border-color 140ms ease, background 140ms ease, box-shadow 140ms ease;
      }

      .template-preview {
        position: relative;
        min-height: 92px;
        border-radius: 14px;
        border: 1px solid rgba(255, 255, 255, 0.08);
        overflow: hidden;
        background: var(--preview-bg, #152033);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
      }

      .template-preview::before {
        content: "";
        position: absolute;
        inset: 0;
        background: var(--preview-overlay, none);
        opacity: var(--preview-overlay-opacity, 1);
        pointer-events: none;
      }

      .template-preview::after {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 24px;
        background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.18));
        pointer-events: none;
      }

      .preview-layout {
        position: relative;
        z-index: 1;
        height: 100%;
        padding: 10px;
        display: grid;
        grid-template-columns: 1.15fr 0.85fr;
        gap: 8px;
      }

      .preview-stack {
        display: grid;
        gap: 6px;
      }

      .preview-pill,
      .preview-line,
      .preview-panel,
      .preview-bar,
      .preview-dot {
        border-radius: 999px;
      }

      .preview-pill {
        width: 46px;
        height: 10px;
        background: color-mix(in srgb, var(--preview-accent, #5ad8ff) 72%, white 10%);
        opacity: 0.9;
      }

      .preview-line {
        height: 8px;
        background: color-mix(in srgb, var(--preview-ink, #eff6ff) 86%, transparent);
      }

      .preview-line.short {
        width: 58%;
        opacity: 0.75;
      }

      .preview-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 6px;
      }

      .preview-panel {
        min-height: 22px;
        border-radius: 10px;
        border: 1px solid color-mix(in srgb, var(--preview-line, rgba(255,255,255,0.14)) 85%, transparent);
        background: color-mix(in srgb, var(--preview-panel, rgba(255,255,255,0.12)) 88%, transparent);
      }

      .preview-panel.accent {
        background: color-mix(in srgb, var(--preview-accent-2, #9ff5a4) 60%, var(--preview-panel, rgba(255,255,255,0.12)) 40%);
      }

      .preview-side {
        display: grid;
        gap: 6px;
        align-content: start;
      }

      .preview-chart {
        display: flex;
        align-items: end;
        gap: 4px;
        min-height: 54px;
        padding: 8px;
        border-radius: 12px;
        border: 1px solid color-mix(in srgb, var(--preview-line, rgba(255,255,255,0.14)) 85%, transparent);
        background: color-mix(in srgb, var(--preview-panel, rgba(255,255,255,0.12)) 92%, transparent);
      }

      .preview-bar {
        flex: 1 1 0;
        background: var(--preview-accent, #5ad8ff);
        min-height: 16px;
        opacity: 0.92;
      }

      .preview-bar:nth-child(2) {
        height: 26px;
        background: var(--preview-accent-2, #9ff5a4);
      }

      .preview-bar:nth-child(3) {
        height: 36px;
        background: var(--preview-accent-3, #f2b15d);
      }

      .preview-bar:nth-child(4) {
        height: 22px;
      }

      .preview-dots {
        display: flex;
        gap: 5px;
        flex-wrap: wrap;
      }

      .preview-dot {
        width: 10px;
        height: 10px;
        background: color-mix(in srgb, var(--preview-accent, #5ad8ff) 70%, white 8%);
        border: 1px solid rgba(255,255,255,0.14);
      }

      .template-card:hover {
        transform: translateY(-1px);
        border-color: rgba(90, 216, 255, 0.34);
        background: rgba(255, 255, 255, 0.05);
      }

      .template-option input:focus + .template-card {
        border-color: rgba(90, 216, 255, 0.82);
        box-shadow: 0 0 0 4px rgba(90, 216, 255, 0.14);
      }

      .template-option input:checked + .template-card {
        border-color: rgba(90, 216, 255, 0.82);
        background: rgba(90, 216, 255, 0.08);
        box-shadow: 0 0 0 4px rgba(90, 216, 255, 0.12);
      }

      .template-top,
      .template-badges,
      .swatches {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
      }

      .template-top {
        justify-content: space-between;
        align-items: flex-start;
      }

      .template-family {
        font-family: "IBM Plex Mono", monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        font-size: 10px;
        color: var(--muted);
      }

      .swatch {
        width: 18px;
        height: 18px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.16);
      }

      .template-badge {
        display: inline-flex;
        padding: 4px 7px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,0.08);
        background: rgba(255,255,255,0.04);
        color: var(--muted);
        font-family: "IBM Plex Mono", monospace;
        font-size: 10px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .form-actions {
        display: flex;
        gap: 10px;
        margin-top: 18px;
      }

      .status-strip {
        padding: 12px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        border-radius: 14px;
      }

      .status-strip .eyebrow {
        margin: 0;
        padding: 4px 8px;
        font-size: 10px;
        border-color: rgba(90, 216, 255, 0.4);
      }

      .status-strip-text {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .report-list {
        display: grid;
        gap: 14px;
        margin-top: 16px;
      }

      .report-card {
        position: relative;
        padding: 18px;
        border-radius: 20px;
        border: 1px solid var(--line);
        background: var(--panel-strong);
        overflow: hidden;
      }

      .report-card::before {
        content: "";
        position: absolute;
        inset: auto 0 0 0;
        height: 2px;
        background: linear-gradient(90deg, var(--cyan), transparent 70%);
      }

      .report-head,
      .report-links,
      .chip-row,
      .insight-grid {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .report-head {
        justify-content: space-between;
        align-items: flex-start;
      }

      .chip {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 7px 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        color: var(--muted);
        font-size: 11px;
      }

      .chip.status-running,
      .chip.status-queued {
        color: var(--cyan);
        border: 1px solid rgba(90, 216, 255, 0.2);
      }

      .chip.status-ready {
        color: var(--lime);
        border: 1px solid rgba(159, 245, 164, 0.18);
      }

      .chip.status-failed {
        color: var(--coral);
        border: 1px solid rgba(255, 133, 115, 0.18);
      }

      .pulse {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: currentColor;
        box-shadow: 0 0 0 0 currentColor;
        animation: ping 1.8s infinite;
      }

      .report-links {
        margin-top: 14px;
      }

      .text-link {
        color: var(--cyan);
        background: none;
        padding: 0;
      }

      .insight-grid {
        margin-top: 18px;
      }

      .insight {
        flex: 1 1 180px;
        min-height: 110px;
        padding: 16px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
      }

      .insight strong {
        display: block;
        margin-top: 8px;
        font-size: 1.4rem;
      }

      .submit-overlay {
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        background: rgba(4, 10, 18, 0.74);
        backdrop-filter: blur(10px);
        z-index: 20;
      }

      .submit-card {
        width: min(460px, calc(100% - 28px));
        padding: 24px;
        border-radius: 24px;
        border: 1px solid var(--line-strong);
        background: var(--panel-strong);
        box-shadow: var(--shadow);
        display: grid;
        gap: 12px;
        text-align: center;
      }

      .spinner {
        width: 54px;
        height: 54px;
        margin: 0 auto;
        border-radius: 999px;
        border: 3px solid rgba(90, 216, 255, 0.16);
        border-top-color: var(--cyan);
        border-right-color: var(--lime);
        animation: spin 1s linear infinite;
      }

      .is-submitting .topbar,
      .is-submitting .layout {
        pointer-events: none;
        filter: blur(1px);
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      @keyframes ping {
        0% { box-shadow: 0 0 0 0 rgba(90, 216, 255, 0.5); }
        70% { box-shadow: 0 0 0 10px rgba(90, 216, 255, 0); }
        100% { box-shadow: 0 0 0 0 rgba(90, 216, 255, 0); }
      }

      @media (max-width: 980px) {
        .layout {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 680px) {
        .shell {
          width: min(100% - 18px, 1240px);
        }

        .topbar {
          flex-direction: column;
          align-items: flex-start;
        }

        .form-actions,
        .status-strip {
          flex-direction: column;
          align-items: stretch;
        }

        .template-picker {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <section class="topbar">
        <div class="profile">
          {% if user.avatar_url %}<img src="{{ user.avatar_url }}" alt="{{ user.login }} avatar" />{% endif %}
          <div>
            <div class="eyebrow">Mission Control</div>
            <h1>{{ user.name or user.login }}</h1>
            <p class="muted">@{{ user.login }} / queue reports / publish clean share links</p>
          </div>
        </div>
        <div style="display: flex; gap: 16px; align-items: center;">
          <a href="/gallery" style="color: var(--cyan); text-decoration: none; font-family: 'IBM Plex Mono', monospace; font-size: 12px; text-transform: uppercase; letter-spacing: 0.05em;">Public Gallery</a>
          <form method="post" action="/auth/logout">
          <button class="logout" type="submit">Log out</button>
          </form>
        </div>
      </section>

      <section class="layout">
        <article class="panel">
          <span class="eyebrow">Generate</span>
          <h2 style="margin-top: 12px;">Launch a new snapshot</h2>
          <p class="muted" style="margin-top: 10px;">Pick your time window, decide how public it should be, and choose whether you want metadata retained for future reruns.</p>
          {% if form_error %}
          <div id="formError" class="form-error" role="alert">{{ form_error }}</div>
          {% else %}
          <div id="formError" class="form-error" role="alert" hidden></div>
          {% endif %}

          <form id="reportForm" method="post" action="/dashboard/reports">
            <div class="field">
              <label for="since_spec">Time window</label>
              <select id="since_spec" name="since_spec">
                <option value="7d" {% if form_values.since_spec == '7d' %}selected{% endif %}>7 days</option>
                <option value="30d" {% if form_values.since_spec == '30d' %}selected{% endif %}>30 days</option>
                <option value="90d" {% if form_values.since_spec == '90d' %}selected{% endif %}>90 days</option>
                <option value="180d" {% if form_values.since_spec == '180d' %}selected{% endif %}>180 days</option>
                <option value="365d" {% if form_values.since_spec == '365d' %}selected{% endif %}>365 days</option>
              </select>
            </div>
            <div class="field">
              <label for="title">Report title</label>
              <input id="title" name="title" maxlength="120" placeholder="GitHub Activity / Last 30d" value="{{ form_values.title }}" />
            </div>
            <div class="field">
              <label for="visibility">Visibility</label>
              <select id="visibility" name="visibility">
                <option value="unlisted" {% if form_values.visibility == 'unlisted' %}selected{% endif %}>unlisted - Link sharing only</option>
                <option value="public" {% if form_values.visibility == 'public' %}selected{% endif %}>public - Appears on your subdomain & public gallery</option>
                <option value="private" {% if form_values.visibility == 'private' %}selected{% endif %}>private - Only you can view while logged in</option>
              </select>
            </div>
            <div class="field">
              <label>Report template</label>
              <div class="template-picker" role="radiogroup" aria-label="Report template picker">
                {% for template in report_templates %}
                {% set theme = get_report_theme(template.key) %}
                <label class="template-option">
                  <input type="radio" name="template_key" value="{{ template.key }}" {% if form_values.template_key == template.key %}checked{% endif %} />
                  <span class="template-card">
                    <span class="template-preview"
                      style="--preview-bg: {{ theme.background_css }}; --preview-overlay: {{ theme.overlay_css }}; --preview-overlay-opacity: {{ theme.overlay_opacity }}; --preview-ink: {{ theme.ink }}; --preview-line: {{ theme.line }}; --preview-panel: {{ theme.panel_strong }}; --preview-accent: {{ theme.accent }}; --preview-accent-2: {{ theme.accent_2 }}; --preview-accent-3: {{ theme.accent_3 }};">
                      <span class="preview-layout">
                        <span class="preview-stack">
                          <span class="preview-pill"></span>
                          <span class="preview-line"></span>
                          <span class="preview-line short"></span>
                          <span class="preview-grid">
                            <span class="preview-panel accent"></span>
                            <span class="preview-panel"></span>
                            <span class="preview-panel"></span>
                            <span class="preview-panel accent"></span>
                          </span>
                        </span>
                        <span class="preview-side">
                          <span class="preview-chart">
                            <span class="preview-bar" style="height: 18px;"></span>
                            <span class="preview-bar" style="height: 28px;"></span>
                            <span class="preview-bar" style="height: 40px;"></span>
                            <span class="preview-bar" style="height: 24px;"></span>
                          </span>
                          <span class="preview-dots">
                            <span class="preview-dot"></span>
                            <span class="preview-dot"></span>
                            <span class="preview-dot"></span>
                          </span>
                        </span>
                      </span>
                    </span>
                    <span class="template-top">
                      <span>
                        <strong>{{ template.label }}</strong>
                        <span class="template-family">{{ template.family }}</span>
                      </span>
                      <span class="template-family">{{ template.tone }}</span>
                    </span>
                    <span class="muted">{{ template.description }}</span>
                    <span class="swatches">
                      {% for swatch in template.swatches %}
                      <span class="swatch" style="background: {{ swatch }};"></span>
                      {% endfor %}
                    </span>
                    <span class="template-badges">
                      {% for badge in template.badges %}
                      <span class="template-badge">{{ badge }}</span>
                      {% endfor %}
                    </span>
                  </span>
                </label>
                {% endfor %}
              </div>
            </div>
            <div class="field">
              <label>Include private activity</label>
              <label class="checkbox-row"><input id="include_private" name="include_private" type="checkbox" value="true" {% if form_values.include_private %}checked{% endif %} /> <span>allowed, but the report must remain private if this is enabled</span></label>
            </div>
            <div class="field">
              <label for="expires_in_days">Expiry in days</label>
              <select id="expires_in_days" name="expires_in_days">
                <option value="7" {% if form_values.expires_in_days == '7' %}selected{% endif %}>7 days</option>
                <option value="14" {% if form_values.expires_in_days == '14' %}selected{% endif %}>14 days</option>
                <option value="30" {% if form_values.expires_in_days == '30' %}selected{% endif %}>30 days</option>
                <option value="60" {% if form_values.expires_in_days == '60' %}selected{% endif %}>60 days</option>
                <option value="90" {% if form_values.expires_in_days == '90' %}selected{% endif %}>90 days</option>
              </select>
              <p id="expiryPolicyHint" class="muted field-hint">Public reports can last up to 30 days.</p>
            </div>
            <div class="field">
              <label>Store metadata</label>
              <label class="checkbox-row"><input id="store_metadata" name="store_metadata" type="checkbox" value="true" {% if form_values.store_metadata %}checked{% endif %} /> <span>opt in if you want JSON/context retained for history and easier reruns</span></label>
            </div>
            {% if allow_sample_reports %}
            <div class="field">
              <label>Use sample data</label>
              <label class="checkbox-row"><input id="sample_data" name="sample_data" type="checkbox" value="true" {% if form_values.sample_data %}checked{% endif %} /> <span>demo mode without touching your real GitHub activity</span></label>
            </div>
            {% endif %}
            <div class="form-actions">
              <button id="submitButton" class="primary" type="submit"><span class="button-text">Generate report</span></button>
              <span class="muted">You will be redirected to a live status page while it generates.</span>
            </div>
          </form>
        </article>

        <div class="stack">
          <section class="status-strip">
            <div class="status-strip-text">
              <span class="eyebrow">Policy</span>
              <h3 style="font-size: 14px; font-weight: 500; margin: 0;">Host the page, not the guts</h3>
            </div>
            <div class="chip-row" style="gap: 6px;">
              <span class="chip" style="font-size: 10px; padding: 4px 8px;">HTML retained</span>
              <span class="chip" style="font-size: 10px; padding: 4px 8px;">Metadata opt-in</span>
              <span class="chip" style="font-size: 10px; padding: 4px 8px;">Private activity stays private</span>
            </div>
          </section>

          <section class="panel">
            <span class="eyebrow">Your queue</span>
            <h2 style="margin-top: 12px;">Reports and share surfaces</h2>
            <div class="insight-grid">
              <div class="insight">
                <div class="muted">Per-user host</div>
                <strong>{{ user.login|lower }}.ghstats.ussyco.de</strong>
                <div class="muted">Serves the latest public snapshot once one exists.</div>
              </div>
              <div class="insight">
                <div class="muted">Direct share links</div>
                <strong>/r/&lt;slug&gt;</strong>
                <div class="muted">Stable links for specific report identities.</div>
              </div>
            </div>

            <div class="report-list">
              {% if reports %}
                {% for report in reports %}
                <article class="report-card">
                  <div class="report-head">
                    <div>
                      <div class="eyebrow">Report node</div>
                      <h3 style="margin-top: 10px;">{{ report.title }}</h3>
                    </div>
                    <span class="chip status-{{ report.status }}">{% if report.status in ['queued', 'running'] %}<span class="pulse"></span>{% endif %}{{ report.status }}</span>
                  </div>
                  <div class="chip-row" style="margin-top: 14px;">
                    <span class="chip">{{ report.since_spec }}</span>
                    <span class="chip">{{ report.visibility }}</span>
                    {% if report.include_private %}<span class="chip">private activity</span>{% endif %}
                    {% if report.store_metadata %}<span class="chip">metadata retained</span>{% endif %}
                    <span class="chip">template {{ report.template_key }}</span>
                  </div>
                  <div class="report-links">
                    <a class="text-link" href="/dashboard/reports/{{ report.id }}">Manage</a>
                    <a class="text-link" href="{{ report.share_url }}">Share link</a>
                    {% if report.host_url %}<a class="text-link" href="{{ report.host_url }}">Subdomain</a>{% endif %}
                  </div>
                </article>
                {% endfor %}
              {% else %}
                <p class="muted" style="margin-top: 10px;">No reports yet. Make the first one and the dashboard starts looking alive.</p>
              {% endif %}
            </div>
          </section>
        </div>
      </section>
    </main>

    <div id="submitOverlay" class="submit-overlay" hidden>
      <div class="submit-card">
        <div class="spinner" aria-hidden="true"></div>
        <h3>Creating your report</h3>
        <p class="muted">We are queueing the job and opening its status page. This can take a bit if GitHub has a lot to churn.</p>
        <p class="muted">Please keep this tab open until the redirect happens.</p>
      </div>
    </div>

    <script>
      const form = document.getElementById('reportForm');
      const overlay = document.getElementById('submitOverlay');
      const submitButton = document.getElementById('submitButton');
      const visibilityField = document.getElementById('visibility');
      const expiryField = document.getElementById('expires_in_days');
      const errorBox = document.getElementById('formError');
      const expiryPolicyHint = document.getElementById('expiryPolicyHint');

      if (form && overlay && submitButton && visibilityField && expiryField) {
        const syncExpiryPolicy = () => {
          const isPublic = visibilityField.value === 'public';

          for (const option of expiryField.options) {
            const days = Number(option.value);
            const allowed = !isPublic || days <= 30;
            option.disabled = !allowed;
            option.hidden = !allowed;
          }

          if (isPublic && Number(expiryField.value) > 30) {
            expiryField.value = '30';
          }

          if (expiryPolicyHint) {
            expiryPolicyHint.hidden = !isPublic;
          }
        };

        const showError = (message) => {
          if (!errorBox) {
            return;
          }
          errorBox.textContent = message;
          errorBox.hidden = false;
        };

        visibilityField.addEventListener('change', syncExpiryPolicy);
        expiryField.addEventListener('change', () => {
          if (errorBox) {
            errorBox.hidden = true;
          }
        });
        syncExpiryPolicy();

        form.addEventListener('submit', (event) => {
          if (visibilityField.value === 'public' && Number(expiryField.value) > 30) {
            event.preventDefault();
            showError('Public reports must expire within 30 days.');
            expiryField.focus();
            return;
          }

          document.body.classList.add('is-submitting');
          overlay.hidden = false;
          submitButton.disabled = true;
          submitButton.textContent = 'Starting report...';
        });
      }
    </script>
  </body>
</html>
