<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ report.title }} - ghstatsussy hosted</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      :root {
        --bg-0: #09111d;
        --bg-1: #0d1727;
        --panel: rgba(10, 17, 30, 0.82);
        --panel-strong: rgba(9, 15, 26, 0.94);
        --line: rgba(142, 194, 255, 0.13);
        --line-strong: rgba(142, 194, 255, 0.28);
        --ink: #ebf4ff;
        --muted: #8fa4bb;
        --cyan: #5ad8ff;
        --lime: #9ff5a4;
        --amber: #f2b15d;
        --coral: #ff8573;
        --shadow: 0 28px 90px rgba(0, 0, 0, 0.42);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: "IBM Plex Sans", sans-serif;
        color: var(--ink);
        background:
          radial-gradient(circle at top left, rgba(90, 216, 255, 0.14), transparent 24%),
          linear-gradient(160deg, #07101a 0%, #0b1420 52%, #0f1728 100%);
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image:
          linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px);
        background-size: 34px 34px;
        pointer-events: none;
      }

      .shell {
        width: min(1080px, calc(100% - 28px));
        margin: 24px auto 36px;
        position: relative;
        z-index: 1;
      }

      .panel,
      .status-panel,
      .mini-panel {
        background: var(--panel);
        border: 1px solid var(--line);
        border-radius: 28px;
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .panel,
      .status-panel,
      .mini-panel {
        padding: 22px;
      }

      .eyebrow,
      .chip,
      .step-label,
      .meta-label,
      .button-text {
        font-family: "IBM Plex Mono", monospace;
        text-transform: uppercase;
        letter-spacing: 0.1em;
      }

      .top,
      .actions,
      .link-row,
      .steps,
      .grid {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .top {
        justify-content: space-between;
        align-items: center;
      }

      h1,
      h2,
      h3,
      p {
        margin: 0;
      }

      .muted {
        color: var(--muted);
      }

      .eyebrow {
        display: inline-flex;
        width: fit-content;
        padding: 8px 10px;
        border-radius: 999px;
        border: 1px solid rgba(90, 216, 255, 0.22);
        color: var(--cyan);
        font-size: 11px;
      }

      .chip {
        display: inline-flex;
        gap: 8px;
        align-items: center;
        padding: 7px 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        color: var(--muted);
        font-size: 11px;
      }

      .chip.running,
      .chip.queued {
        color: var(--cyan);
        border: 1px solid rgba(90, 216, 255, 0.2);
      }

      .chip.ready {
        color: var(--lime);
        border: 1px solid rgba(159, 245, 164, 0.18);
      }

      .chip.failed {
        color: var(--coral);
        border: 1px solid rgba(255, 133, 115, 0.18);
      }

      .grid {
        margin-top: 18px;
        align-items: stretch;
      }

      .status-panel {
        flex: 1 1 420px;
      }

      .mini-panel {
        flex: 1 1 260px;
      }

      .spinner-wrap {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 18px;
      }

      .spinner {
        width: 56px;
        height: 56px;
        border-radius: 999px;
        border: 3px solid rgba(90, 216, 255, 0.14);
        border-top-color: var(--cyan);
        border-right-color: var(--lime);
        animation: spin 1s linear infinite;
      }

      .beacon-card {
        margin-top: 18px;
        padding: 18px;
        border-radius: 20px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
        display: grid;
        gap: 14px;
      }

      .beacon-stack,
      .progress-meta {
        display: flex;
        gap: 14px;
        align-items: center;
        flex-wrap: wrap;
      }

      .progress-meta {
        align-items: flex-start;
      }

      .micro {
        font-family: "IBM Plex Mono", monospace;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        font-size: 11px;
      }

      .beacon-ring {
        width: 58px;
        height: 58px;
        border-radius: 999px;
        border: 1px solid var(--line-strong);
        display: grid;
        place-items: center;
        position: relative;
        flex: 0 0 auto;
      }

      .beacon-ring::after {
        content: "";
        position: absolute;
        inset: -6px;
        border-radius: inherit;
        border: 1px solid rgba(90, 216, 255, 0.12);
        animation: beaconPulse 2.4s ease-in-out infinite;
      }

      .beacon-core {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: var(--cyan);
        box-shadow: 0 0 0 10px rgba(90, 216, 255, 0.1);
      }

      .beacon-queued .beacon-core {
        background: var(--amber);
        box-shadow: 0 0 0 10px rgba(242, 177, 93, 0.08);
      }

      .beacon-ready .beacon-core {
        background: var(--lime);
        box-shadow: 0 0 0 10px rgba(159, 245, 164, 0.08);
      }

      .beacon-failed .beacon-core {
        background: var(--coral);
        box-shadow: 0 0 0 10px rgba(255, 133, 115, 0.08);
      }

      .progress-rail {
        position: relative;
        height: 8px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.06);
        overflow: hidden;
      }

      .progress-fill {
        position: absolute;
        inset: 0 auto 0 0;
        border-radius: inherit;
        background: linear-gradient(90deg, var(--cyan), var(--lime));
      }

      .progress-scan {
        position: absolute;
        top: 0;
        left: -30%;
        width: 30%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.45), transparent);
        opacity: 0;
      }

      .progress-rail.indeterminate .progress-scan {
        opacity: 1;
        animation: scan 1.9s linear infinite;
      }

      .steps {
        margin-top: 18px;
        display: grid;
        gap: 12px;
      }

      .step {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        padding: 12px 14px;
        border-radius: 16px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.03);
      }

      .step-dot {
        width: 11px;
        height: 11px;
        border-radius: 999px;
        background: rgba(143, 164, 187, 0.4);
        margin-top: 4px;
      }

      .step.done .step-dot,
      .step.active .step-dot {
        background: var(--cyan);
        box-shadow: 0 0 0 8px rgba(90, 216, 255, 0.08);
      }

      .step.done {
        border-color: rgba(159, 245, 164, 0.18);
      }

      .step.active {
        border-color: rgba(90, 216, 255, 0.22);
      }

      .link-row {
        margin-top: 18px;
      }

      .link-row a,
      .back-link {
        color: var(--cyan);
        text-decoration: none;
      }

      .disabled-link {
        color: var(--muted);
        cursor: not-allowed;
      }

      button {
        appearance: none;
        border: 0;
        border-radius: 16px;
        padding: 13px 16px;
        background: linear-gradient(135deg, var(--cyan), var(--lime));
        color: #06111c;
        font: inherit;
        font-weight: 700;
        cursor: pointer;
      }

      .refreshing button {
        opacity: 0.7;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      @keyframes scan {
        from { left: -30%; }
        to { left: 100%; }
      }

      @keyframes beaconPulse {
        0%, 100% { transform: scale(0.92); opacity: 0.4; }
        50% { transform: scale(1.06); opacity: 0.9; }
      }

      @media (max-width: 720px) {
        .top {
          align-items: flex-start;
          flex-direction: column;
        }

        .spinner-wrap {
          align-items: flex-start;
          flex-direction: column;
        }
      }

    </style>
    {% if report.status in ['queued', 'running'] %}
    <meta http-equiv="refresh" content="8" />
    {% endif %}
  </head>
  <body>
    <main class="shell">
      <section class="panel">
        <div class="top">
          <div>
            <span class="eyebrow">Report detail</span>
            <h1 style="margin-top: 12px;">{{ report.title }}</h1>
            <p class="muted" style="margin-top: 10px;">Track the queue, watch the worker churn, and open the hosted result when it lands.</p>
          </div>
          <a class="back-link" href="/dashboard">Back to dashboard</a>
        </div>

        <div class="actions" style="margin-top: 18px;">
          <span class="chip {{ report.status }}">{{ report.status }}</span>
          <span class="chip">{{ report.since_spec }}</span>
          <span class="chip">{{ report.visibility }}</span>
          <span class="chip">template {{ report.template_key }}</span>
          {% if report.include_private %}<span class="chip">private activity</span>{% endif %}
          {% if report.store_metadata %}<span class="chip">metadata retained</span>{% endif %}
        </div>

        <div class="grid">
          <div id="progressShell" style="flex: 1 1 420px;">
            {% include 'web/_report_progress.html.j2' %}
          </div>

          <section class="mini-panel">
            {% set ready = report.status == 'ready' %}
            <div class="eyebrow">Access</div>
            <h3 style="margin-top: 12px;">Share surfaces</h3>
            <div class="link-row">
              {% if ready and snapshot %}
              <a href="{{ report.share_url }}">Open share link</a>
              {% else %}
              <span class="disabled-link">Share link available when ready</span>
              {% endif %}
            </div>
            <div class="link-row">
              {% if ready and report.host_url %}
              <a href="{{ report.host_url }}">Open subdomain link</a>
              {% else %}
              <span class="disabled-link">Subdomain will light up after publish</span>
              {% endif %}
            </div>
            <div class="link-row">
              {% if snapshot %}<span class="muted">Snapshot v{{ snapshot.version }}</span>{% endif %}
              {% if report.expires_at %}<span class="muted">Expires {{ report.expires_at }}</span>{% endif %}
            </div>
          </section>
        </div>

        {% if report.status == 'ready' %}
        <section class="panel" style="margin-top: 18px; border-radius: 20px;">
          <div class="eyebrow">Presentation Configuration</div>
          <h3 style="margin-top: 12px;">Customize Report</h3>
          <p class="muted" style="margin-top: 8px;">Apply themes and toggle sections instantly without regenerating.</p>
          <div class="grid" style="grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));">
            <div>
              <label class="step-label" style="display:block; margin-bottom: 8px;">Theme</label>
              <select id="themeSelect" style="width: 100%; padding: 10px; border-radius: 8px; background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--line);">
                <option value="default" {% if report.template_key == 'default' %}selected{% endif %}>Default</option>
                <option value="ledger" {% if report.template_key == 'ledger' %}selected{% endif %}>Ledger</option>
                <option value="transit" {% if report.template_key == 'transit' %}selected{% endif %}>Transit</option>
                <option value="archive" {% if report.template_key == 'archive' %}selected{% endif %}>Archive</option>
                <option value="scrapbook" {% if report.template_key == 'scrapbook' %}selected{% endif %}>Scrapbook</option>
                <option value="orbital" {% if report.template_key == 'orbital' %}selected{% endif %}>Orbital</option>
                <option value="fieldnotes" {% if report.template_key == 'fieldnotes' %}selected{% endif %}>Fieldnotes</option>
                <option value="signalroom" {% if report.template_key == 'signalroom' %}selected{% endif %}>Signalroom</option>
                <option value="gallery" {% if report.template_key == 'gallery' %}selected{% endif %}>Gallery</option>
                <option value="tapearchive" {% if report.template_key == 'tapearchive' %}selected{% endif %}>Tapearchive</option>
                <option value="cyberpunk" {% if report.template_key == 'cyberpunk' %}selected{% endif %}>Cyberpunk</option>
                <option value="glassmorphism" {% if report.template_key == 'glassmorphism' %}selected{% endif %}>Glassmorphism</option>
                <option value="brutalism" {% if report.template_key == 'brutalism' %}selected{% endif %}>Brutalism</option>
                <option value="retro_os" {% if report.template_key == 'retro_os' %}selected{% endif %}>Retro OS</option>
                <option value="holo" {% if report.template_key == 'holo' %}selected{% endif %}>Holo</option>
                <option value="synthwave" {% if report.template_key == 'synthwave' %}selected{% endif %}>Synthwave</option>
                <option value="paper" {% if report.template_key == 'paper' %}selected{% endif %}>Paper</option>
                <option value="monochrome" {% if report.template_key == 'monochrome' %}selected{% endif %}>Monochrome</option>
                <option value="matrix" {% if report.template_key == 'matrix' %}selected{% endif %}>Matrix</option>
                <option value="liquid" {% if report.template_key == 'liquid' %}selected{% endif %}>Liquid</option>
              </select>
            </div>
            <div>
              <label class="step-label" style="display:block; margin-bottom: 8px;">Text Overrides</label>
              <input type="text" id="heroEyebrowInput" placeholder="Hero Eyebrow (e.g. Developer Report)" style="width: 100%; padding: 10px; margin-bottom: 8px; border-radius: 8px; background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--line);" value="{{ report.presentation_config.get('textOverrides', {}).get('hero_eyebrow', '') if report.presentation_config else '' }}" />
              <input type="text" id="heroTitleInput" placeholder="Hero Title (e.g. Activity Summary)" style="width: 100%; padding: 10px; margin-bottom: 8px; border-radius: 8px; background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--line);" value="{{ report.presentation_config.get('textOverrides', {}).get('hero_title', '') if report.presentation_config else '' }}" />
              <input type="text" id="heroCopyInput" placeholder="Hero Copy" style="width: 100%; padding: 10px; margin-bottom: 8px; border-radius: 8px; background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--line);" value="{{ report.presentation_config.get('textOverrides', {}).get('hero_copy', '') if report.presentation_config else '' }}" />
              <input type="text" id="notesHeadingInput" placeholder="Notes Heading (e.g. Caveats)" style="width: 100%; padding: 10px; border-radius: 8px; background: rgba(255,255,255,0.05); color: white; border: 1px solid var(--line);" value="{{ report.presentation_config.get('textOverrides', {}).get('notes_heading', '') if report.presentation_config else '' }}" />
            </div>
            <div>
              <label class="step-label" style="display:block; margin-bottom: 8px;">Visible Sections</label>
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 8px; max-height: 150px; overflow-y: auto; padding-right: 10px;">
                {% set vis = report.presentation_config.get('visibleSections', ['hero', 'profile_summary', 'key_stats', 'timeline_commits', 'timeline_loc', 'activity_heatmap', 'language_mix', 'language_breakdown', 'highlights', 'repositories', 'notes_and_warnings', 'footer_meta']) if report.presentation_config else ['hero', 'profile_summary', 'key_stats', 'timeline_commits', 'timeline_loc', 'activity_heatmap', 'language_mix', 'language_breakdown', 'highlights', 'repositories', 'notes_and_warnings', 'footer_meta'] %}
                
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="hero" {% if 'hero' in vis %}checked{% endif %}> Hero</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="profile_summary" {% if 'profile_summary' in vis %}checked{% endif %}> Profile</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="key_stats" {% if 'key_stats' in vis %}checked{% endif %}> Stats</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="timeline_commits" {% if 'timeline_commits' in vis %}checked{% endif %}> Commits Chart</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="timeline_loc" {% if 'timeline_loc' in vis %}checked{% endif %}> LOC Chart</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="activity_heatmap" {% if 'activity_heatmap' in vis %}checked{% endif %}> Heatmap</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="language_mix" {% if 'language_mix' in vis %}checked{% endif %}> Lang Mix</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="language_breakdown" {% if 'language_breakdown' in vis %}checked{% endif %}> Lang Stats</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="highlights" {% if 'highlights' in vis %}checked{% endif %}> Highlights</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="repositories" {% if 'repositories' in vis %}checked{% endif %}> Repositories</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="notes_and_warnings" {% if 'notes_and_warnings' in vis %}checked{% endif %}> Warnings</label>
                <label style="font-size: 13px; display: flex; align-items: center; gap: 6px;"><input type="checkbox" class="section-toggle" value="footer_meta" {% if 'footer_meta' in vis %}checked{% endif %}> Footer Meta</label>
              </div>
            </div>
          </div>
          <div style="margin-top: 18px; display: flex; gap: 12px; align-items: center;">
            <button id="savePresentationBtn" type="button">Save Presentation</button>
            <button id="resetPresentationBtn" type="button" style="background: transparent; border: 1px solid var(--line); color: var(--muted);">Reset Defaults</button>
            <span id="saveStatus" class="muted"></span>
          </div>
        </section>
        {% endif %}

        <form id="refreshForm" method="post" action="/dashboard/reports/{{ report.id }}/refresh" class="actions" style="margin-top: 18px;">
          <button type="submit">Refresh report</button>
          <span class="muted">Refreshing creates a new snapshot version without changing the share identity.</span>
        </form>
      </section>
      
      {% if report.status == 'ready' and report.share_url %}
      <section class="panel" style="margin-top: 18px; padding: 0; border-radius: 20px; overflow: hidden; height: 800px; display: flex; flex-direction: column;">
        <div style="background: rgba(0,0,0,0.2); padding: 12px 20px; border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; align-items: center;">
          <span class="eyebrow" style="margin: 0;">Live Preview</span>
          <a href="{{ report.share_url }}" target="_blank" style="color: var(--cyan); text-decoration: none; font-size: 13px;">Open in new tab &nearr;</a>
        </div>
        <iframe id="reportPreviewFrame" src="{{ report.share_url }}" style="width: 100%; height: 100%; border: none; background: #fff;"></iframe>
      </section>
      {% endif %}
    </main>

    <script>
      const latestJobId = {{ report.latest_job_id|tojson if report.latest_job_id else 'null' }};
      const refreshForm = document.getElementById('refreshForm');
      const progressShell = document.getElementById('progressShell');

      if (refreshForm) {
        refreshForm.addEventListener('submit', () => {
          document.body.classList.add('refreshing');
        });
      }

      if (latestJobId && {{ 'true' if report.status in ['queued', 'running'] else 'false' }}) {
        const poll = async () => {
          try {
            const response = await fetch(`/dashboard/reports/{{ report.id }}/progress`, { headers: { 'Accept': 'text/html' } });
            if (!response.ok) {
              return;
            }
            const html = await response.text();
            if (progressShell) {
              progressShell.innerHTML = html;
            }
            const nextState = progressShell?.querySelector('[data-status]')?.getAttribute('data-status');
            if (nextState === 'ready' || nextState === 'succeeded' || nextState === 'failed') {
              window.location.reload();
            }
          } catch (error) {
            console.warn('status poll failed', error);
          }
        };

        window.setInterval(poll, 4000);
      }

      const resetBtn = document.getElementById('resetPresentationBtn');
      if (resetBtn) {
        resetBtn.addEventListener('click', async () => {
          if (!confirm('Are you sure you want to reset to the default theme and visible sections?')) return;
          const statusEl = document.getElementById('saveStatus');
          statusEl.textContent = 'Resetting...';
          resetBtn.disabled = true;

          const payload = {
            themeKey: 'default',
            visibleSections: ["hero", "profile_summary", "key_stats", "timeline_commits", "timeline_loc", "activity_heatmap", "language_mix", "language_breakdown", "highlights", "repositories", "notes_and_warnings", "footer_meta"],
            textOverrides: {}
          };

          try {
            const res = await fetch(`/api/reports/{{ report.id }}/presentation`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });
            if (res.ok) {
              window.location.reload();
            } else {
              statusEl.textContent = 'Failed to reset.';
            }
          } catch (err) {
            statusEl.textContent = 'Error resetting.';
          }
          resetBtn.disabled = false;
        });
      }

      const saveBtn = document.getElementById('savePresentationBtn');
      if (saveBtn) {
        saveBtn.addEventListener('click', async () => {
          const theme = document.getElementById('themeSelect').value;
          const heroEyebrow = document.getElementById('heroEyebrowInput').value.trim();
          const heroTitle = document.getElementById('heroTitleInput').value.trim();
          const heroCopy = document.getElementById('heroCopyInput').value.trim();
          const notesHeading = document.getElementById('notesHeadingInput').value.trim();
          const statusEl = document.getElementById('saveStatus');
          
          statusEl.textContent = 'Saving...';
          saveBtn.disabled = true;

          const visibleSections = Array.from(document.querySelectorAll('.section-toggle:checked')).map(cb => cb.value);

          const payload = {
            themeKey: theme,
            visibleSections: visibleSections
          };
          
          payload.textOverrides = {};
          if (heroEyebrow) payload.textOverrides.hero_eyebrow = heroEyebrow;
          if (heroTitle) payload.textOverrides.hero_title = heroTitle;
          if (heroCopy) payload.textOverrides.hero_copy = heroCopy;
          if (notesHeading) payload.textOverrides.notes_heading = notesHeading;

          try {
            const res = await fetch(`/api/reports/{{ report.id }}/presentation`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify(payload)
            });
            if (res.ok) {
              statusEl.textContent = 'Saved! Refreshing preview...';
              const frame = document.getElementById('reportPreviewFrame');
              if (frame) {
                const baseSrc = frame.src.split('?')[0];
                frame.src = baseSrc + '?t=' + new Date().getTime();
              }
              setTimeout(() => { statusEl.textContent = 'Changes are live.'; }, 1500);
            } else {
              statusEl.textContent = 'Failed to save.';
            }
          } catch (err) {
            statusEl.textContent = 'Error saving.';
          }
          saveBtn.disabled = false;
        });
      }
    </script>
  </body>
</html>
