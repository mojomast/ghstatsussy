<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ report.title }} - ghstatsussy hosted</title>
    <style>
      :root {
        --bg: #f4efe6;
        --panel: rgba(255,251,244,0.86);
        --ink: #18222f;
        --muted: #576576;
        --accent: #0f766e;
        --warn: #d97706;
        --shadow: 0 28px 70px rgba(17,24,39,0.16);
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: "Space Grotesk", "Trebuchet MS", sans-serif;
        color: var(--ink);
        background: linear-gradient(165deg, #f8f2e8 0%, #f0e4cf 100%);
        padding: 24px;
      }
      .shell { width: min(980px, 100%); margin: 0 auto; }
      .panel {
        background: var(--panel);
        border-radius: 28px;
        padding: 22px;
        border: 1px solid rgba(255,255,255,0.56);
        box-shadow: var(--shadow);
      }
      h1,h2,p { margin: 0; }
      .muted { color: var(--muted); }
      .row { display: flex; justify-content: space-between; align-items: center; gap: 14px; flex-wrap: wrap; }
      .meta { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 16px; }
      .chip { padding: 8px 12px; border-radius: 999px; background: rgba(24,34,47,0.07); }
      .links { display: flex; gap: 14px; flex-wrap: wrap; margin-top: 18px; }
      .links a { color: var(--accent); text-decoration: none; font-weight: 700; }
      .actions { display: flex; gap: 10px; margin-top: 18px; }
      button {
        border: 0; border-radius: 16px; padding: 12px 16px; font: inherit; font-weight: 700; cursor: pointer;
        background: linear-gradient(135deg, var(--accent), var(--warn)); color: white;
      }
    </style>
  </head>
  <body>
    <main class="shell">
      <section class="panel">
        <div class="row">
          <div>
            <div class="muted">Report detail</div>
            <h1>{{ report.title }}</h1>
          </div>
          <a href="/dashboard">Back to dashboard</a>
        </div>
        <div class="meta">
          <span class="chip">{{ report.since_spec }}</span>
          <span class="chip">{{ report.visibility }}</span>
          <span class="chip">{{ report.status }}</span>
          {% if report.include_private %}<span class="chip">private activity</span>{% endif %}
          {% if report.store_metadata %}<span class="chip">metadata retained</span>{% endif %}
        </div>
        <div class="links">
          <a href="{{ report.share_url }}">Open share link</a>
          {% if report.host_url %}<a href="{{ report.host_url }}">Open subdomain link</a>{% endif %}
          {% if snapshot %}<span class="muted">Snapshot v{{ snapshot.version }}</span>{% endif %}
          {% if report.expires_at %}<span class="muted">Expires {{ report.expires_at }}</span>{% endif %}
        </div>
        <form method="post" action="/dashboard/reports/{{ report.id }}/refresh" class="actions">
          <button type="submit">Refresh report</button>
        </form>
      </section>
    </main>
  </body>
</html>
