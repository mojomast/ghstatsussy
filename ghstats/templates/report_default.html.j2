{% extends "report_base.html.j2" %}

{% block theme_css %}
<style>
/* Signal Glass (Default) Theme applied to Canonical DOM */
.template-default .hero {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    box-shadow: 0 20px 40px rgba(118, 75, 162, 0.3);
    position: relative;
    overflow: hidden;
    border: none;
}

.template-default .hero::after {
    content: '';
    position: absolute;
    top: -50%; left: -50%; right: -50%; bottom: -50%;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 60%);
    transform: rotate(30deg);
    pointer-events: none;
}

.template-default .hero h1 {
    color: white;
}

.template-default .hero .muted {
    color: rgba(255,255,255,0.8);
}

.template-default .hero-stat {
    background: rgba(255,255,255,0.1);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2);
}

.template-default .hero-stat .label {
    color: rgba(255,255,255,0.9);
}

/* Base sections -> Modern Card styling */
.template-default .panel,
.template-default .chart-card {
    background: white;
    border-radius: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.02);
}

.template-default h2 {
    color: #2d3748;
}

/* Fact lists */
.template-default .fact {
    background: #f7fafc;
    border: none;
    transition: transform 0.2s;
}

.template-default .fact:hover {
    transform: translateY(-2px);
    background: #edf2f7;
}

.template-default .fact h3 {
    color: #2d3748;
}

.template-default .fact-text {
    color: #718096;
}

.template-default .section-kicker {
    color: #4299e1;
    background: #ebf4ff;
    padding: 4px 8px;
    border-radius: 6px;
}
</style>
{% endblock %}
