{% extends "report_base.html.j2" %}

{% block hero %}
<section class="gallery-hero panel" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; padding: 60px 40px; align-items: center; border-bottom: 8px solid var(--accent); border-radius: 8px; margin-bottom: 40px;">
  <div>
    <h1 style="font-family: var(--hero-font); font-size: 3.8rem; line-height: 1; letter-spacing: -0.03em;">{{ theme.hero_title }}</h1>
    <p style="font-size: 1.3rem; margin-top: 24px; max-width: 480px; color: var(--muted); line-height: 1.4;">{{ theme.hero_copy }}</p>
    <div style="margin-top: 32px; display: inline-flex; gap: 12px; font-family: var(--mono-font); text-transform: uppercase; font-size: 0.85rem; border: 1px solid var(--line); padding: 12px 24px; border-radius: 4px; background: var(--panel);">
      <strong>{{ context.meta.subject.login }}</strong>
      <span class="muted">/</span>
      <span class="muted">{{ context.meta.period.days }} DAYS</span>
    </div>
  </div>
  <div style="position: relative; height: 320px; border-radius: 8px; overflow: hidden; border: 1px solid var(--line); box-shadow: 24px 24px 0 color-mix(in srgb, var(--accent) 15%, transparent);">
    {% if context.meta.subject.avatar_url %}
    <img src="{{ context.meta.subject.avatar_url }}" alt="avatar" style="width: 100%; height: 100%; object-fit: cover; filter: sepia(0.4) contrast(1.1);" />
    {% endif %}
    <div style="position: absolute; bottom: 20px; right: 20px; background: var(--panel); padding: 8px 16px; font-family: var(--mono-font); font-size: 0.8rem; border-radius: 2px;">EXHIBIT 01</div>
  </div>
</section>
{% endblock %}

{% block content %}
<div style="display: grid; gap: 40px;">

  <!-- Large Callouts -->
  <section style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px;">
    {% for card in context.stats_cards[:3] %}
    <div style="background: var(--panel-strong); padding: 40px; border-radius: 8px; text-align: center; border: 1px solid var(--line); box-shadow: 0 12px 24px rgba(0,0,0,0.04);">
      <div style="font-family: var(--hero-font); font-size: 3.5rem; color: var(--accent); line-height: 1;">{{ card.value }}</div>
      <div style="font-family: var(--mono-font); text-transform: uppercase; letter-spacing: 0.1em; margin-top: 16px; color: var(--ink); font-weight: bold;">{{ card.label }}</div>
    </div>
    {% endfor %}
  </section>

  <!-- Asymmetric Charts -->
  <section style="display: grid; grid-template-columns: 2.2fr 1fr; gap: 32px; align-items: stretch;">
    <div style="background: var(--panel); border: 1px solid var(--line); padding: 32px; border-radius: 8px;">
      <h2 style="font-family: var(--hero-font); margin-bottom: 24px; font-size: 2rem;">Activity Timeline</h2>
      <div style="height: 300px; width: 100%;">
        <canvas id="commitsChart"></canvas>
      </div>
    </div>
    <div style="background: var(--accent-3); color: white; padding: 32px; border-radius: 8px; display: flex; flex-direction: column; justify-content: space-between;">
      <div>
        <div style="font-family: var(--mono-font); font-size: 0.85rem; opacity: 0.8; letter-spacing: 0.05em; margin-bottom: 8px;">TOTAL LOC ADDED</div>
        <div style="font-family: var(--hero-font); font-size: 4rem; line-height: 1;">+{{ context.chart_datasets.loc_timeline.series[0]['values']|sum }}</div>
      </div>
      <div>
        <div style="font-family: var(--mono-font); font-size: 0.85rem; opacity: 0.8; letter-spacing: 0.05em; margin-bottom: 8px;">TOTAL LOC DELETED</div>
        <div style="font-family: var(--hero-font); font-size: 4rem; line-height: 1;">-{{ context.chart_datasets.loc_timeline.series[1]['values']|sum }}</div>
      </div>
    </div>
  </section>

  <!-- Masonry Highlights & Heatmap -->
  <section style="column-count: 2; column-gap: 32px; display: block;">
    <div style="break-inside: avoid; background: var(--panel-strong); padding: 40px; border: 1px solid var(--line); border-radius: 8px; margin-bottom: 32px; border-top: 6px solid var(--accent-2);">
      <h3 style="font-family: var(--hero-font); font-size: 1.8rem; margin-bottom: 24px;">Language Palette</h3>
      <div style="display: grid; gap: 16px;">
        {% for lang in context.language_slices %}
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="width: 16px; height: 16px; border-radius: 50%; background: {{ lang.color }};"></div>
            <span style="font-weight: bold;">{{ lang.name }}</span>
          </div>
          <div class="muted" style="font-family: var(--mono-font);">{{ lang.percent }}%</div>
        </div>
        {% endfor %}
      </div>
    </div>

    {% for item in context.highlights %}
    <div style="break-inside: avoid; background: var(--panel); padding: 32px; border: 1px solid var(--line); border-radius: 8px; margin-bottom: 32px;">
      <div class="muted" style="font-family: var(--mono-font); font-size: 0.8rem; text-transform: uppercase; margin-bottom: 12px;">{{ item.kind }}</div>
      <h3 style="font-family: var(--hero-font); font-size: 1.5rem; margin-bottom: 12px; line-height: 1.2;">{{ item.title }}</h3>
      <p style="color: var(--muted); line-height: 1.5;">{{ item.text }}</p>
    </div>
    {% endfor %}

    <div style="break-inside: avoid; background: var(--panel-strong); padding: 40px; border: 1px solid var(--line); border-radius: 8px; margin-bottom: 32px;">
      <h3 style="font-family: var(--hero-font); font-size: 1.8rem; margin-bottom: 24px;">Commit Heatmap</h3>
      <div class="calendar-grid">
        {% for week in context.heatmap.weeks %}
          {% for day in week.days %}
          <div class="cell level-{{ day.level }}" title="{{ day.tooltip }}" style="border-radius: 50%;"></div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </section>

</div>
{% endblock %}