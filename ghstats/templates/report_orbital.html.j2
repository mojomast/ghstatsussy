{% extends "report_base.html.j2" %}

{% block theme_css %}
<style>

/* Orbital Telemetry Theme */
.template-orbital {
  font-family: var(--body-font);
}
.template-orbital h1, .template-orbital h2, .template-orbital .section-kicker {
  font-family: var(--mono-font);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}
.template-orbital .hero {
  border: 1px solid var(--line);
  border-bottom: 4px solid var(--accent);
  background: var(--panel);
}
.template-orbital .profile-card img {
  filter: grayscale(100%) contrast(1.2) sepia(100%) hue-rotate(180deg);
  border-radius: 50%;
}
.template-orbital .section-kicker {
  color: var(--accent);
}
.template-orbital .section-kicker::before {
  content: "[ ";
}
.template-orbital .section-kicker::after {
  content: " ]";
}
.template-orbital .hero-stat {
  border: none;
  border-left: 3px solid var(--accent);
  border-radius: 0;
  background: transparent;
}
.template-orbital .panel, .template-orbital .chart-card, .template-orbital .repo-card {
  border: 1px solid var(--line);
  background: rgba(6, 11, 22, 0.84);
  border-radius: 4px;
}
.template-orbital .fact {
  border: none;
  border-left: 2px dashed var(--accent-3);
  border-radius: 0;
  background: transparent;
}

</style>
{% endblock %}
