{% extends "report_base.html.j2" %}
{% block theme_css %}
<style>
  :root {
    --ink: #0ff; --muted: #f0f;
  }
/* CYBERPUNK - NEON OVERDRIVE REDESIGN */
body {
    background-color: #050510;
    background-image:
        repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 255, 255, 0.03) 2px, rgba(0, 255, 255, 0.03) 4px),
        linear-gradient(90deg, #111 25%, #050510 50%, #111 75%);
    background-size: 100% 4px, 4px 100%;
    font-family: 'Courier New', Courier, monospace;
    color: #0ff;
    overflow-x: hidden;
    margin: 0;
    padding: 0;
}

/* CRT scanline overlay */
body::after {
    content: "";
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 255, 0.06));
    background-size: 100% 2px, 3px 100%;
    z-index: 9999;
    pointer-events: none;
}

.shell {
    width: 90%;
    max-width: 1200px;
    margin: 50px auto;
    perspective: 1500px;
}

/* Glitch effect for main headings */
h1, h2, h3 {
    text-transform: uppercase;
    color: #fff;
    text-shadow: 2px 2px 0px #f0f, -2px -2px 0px #0ff;
    position: relative;
}

h1::before, h1::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0.8;
}

h1::before {
    color: #0ff;
    z-index: -1;
    transform: translate(-3px, 2px);
}

h1::after {
    color: #f0f;
    z-index: -2;
    transform: translate(3px, -2px);
}

/* Radical Hero Section */
.hero {
    background: linear-gradient(135deg, rgba(255,0,255,0.2) 0%, rgba(0,255,255,0.1) 100%);
    border: 2px solid #0ff;
    border-left: 15px solid #f0f;
    padding: 60px 40px;
    margin-bottom: 50px;
    position: relative;
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 40px), calc(100% - 40px) 100%, 0 100%);
    box-shadow: 0 0 20px rgba(0, 255, 255, 0.4), inset 0 0 30px rgba(255, 0, 255, 0.2);
    transform: rotateX(2deg);
}

.hero::after {
    content: "NEURAL_LINK_ESTABLISHED :: v9.0";
    position: absolute;
    bottom: 5px;
    right: 50px;
    color: #ff0;
    font-size: 14px;
    font-weight: bold;
    letter-spacing: 2px;
}

/* Stats Grid & Cards */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-bottom: 50px;
}

.hero-stat {
    background: #000;
    border: 1px solid #f0f;
    padding: 30px;
    position: relative;
    clip-path: polygon(20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%, 0 20px);
    box-shadow: 5px 5px 0px rgba(255, 0, 255, 0.5);
    transition: transform 0.2s, box-shadow 0.2s;
}

.hero-stat:hover {
    transform: translate(-2px, -2px);
    box-shadow: 7px 7px 0px rgba(0, 255, 255, 0.8);
    border-color: #0ff;
}

.hero-stat .stat-val {
    color: #ff0;
    font-size: 3rem;
    font-weight: 900;
    text-shadow: 0 0 10px rgba(255, 255, 0, 0.8);
    margin-bottom: 5px;
}

.hero-stat .stat-label {
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 1px;
}

/* Panels and Chart Cards */
.panel, .chart-card {
    background: rgba(10, 10, 15, 0.9);
    border: 2px solid #333;
    position: relative;
    padding: 40px 30px;
    margin-bottom: 40px;
    clip-path: polygon(0 20px, 20px 0, 100% 0, 100% calc(100% - 20px), calc(100% - 20px) 100%, 0 100%);
    box-shadow: inset 0 0 15px rgba(0, 255, 255, 0.1);
}

.panel::before, .chart-card::before {
    content: '>> SECURE_PAYLOAD';
    position: absolute;
    top: 0;
    left: 40px;
    background: #0ff;
    color: #000;
    padding: 2px 15px;
    font-size: 12px;
    font-weight: bold;
    letter-spacing: 1px;
    clip-path: polygon(0 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
}

.panel:hover, .chart-card:hover {
    border-color: #f0f;
    box-shadow: 0 0 15px rgba(255, 0, 255, 0.3), inset 0 0 20px rgba(255, 0, 255, 0.2);
}

/* Grids */
.facts-grid, .repo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 25px;
}

/* Repo Card & Fact */
.repo-card, .fact {
    background: #080808;
    border: 1px solid #0ff;
    padding: 20px;
    position: relative;
    clip-path: polygon(0 0, calc(100% - 15px) 0, 100% 15px, 100% 100%, 15px 100%, 0 calc(100% - 15px));
    transition: all 0.3s ease;
}

.repo-card::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 15px;
    height: 15px;
    background: #f0f;
}

.repo-card:hover {
    background: #111;
    border-color: #ff0;
    box-shadow: 0 0 20px rgba(255, 255, 0, 0.2);
    transform: translateY(-5px);
}

/* Chips and Tags */
.chip {
    display: inline-block;
    background: #f0f;
    color: #000 !important;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 900;
    text-transform: uppercase;
    clip-path: polygon(5px 0, 100% 0, calc(100% - 5px) 100%, 0 100%);
    margin-right: 5px;
    box-shadow: 2px 2px 0px rgba(0, 255, 255, 0.8);
}

/* Warnings */
.warning {
    background: repeating-linear-gradient(45deg, rgba(255,0,0,0.1), rgba(255,0,0,0.1) 10px, rgba(0,0,0,0.8) 10px, rgba(0,0,0,0.8) 20px);
    border: 2px solid #ff0055;
    color: #ff0055;
    padding: 20px;
    font-weight: bold;
    text-shadow: 0 0 5px rgba(255,0,85,0.5);
    clip-path: polygon(0 0, 100% 0, 100% calc(100% - 15px), calc(100% - 15px) 100%, 0 100%);
}
</style>
{% endblock %}
