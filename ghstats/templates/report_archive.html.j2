{% extends "report_base.html.j2" %}

{% block theme_css %}
<style>

/* Archive Exhibit Theme */
.template-archive {
  background: #f4efeb;
  color: #3e332a;
}
.template-archive .hero, .template-archive .panel, .template-archive .chart-card {
  background: #fffdfa;
  border: 12px solid #e8e2da;
  border-radius: 2px;
  box-shadow: 0 10px 30px rgba(62,51,42,0.08);
}
.template-archive .hero {
  border-bottom-width: 32px;
}
.template-archive .profile-card img {
  border: 4px solid #fff;
  box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}
.template-archive .section-kicker {
  color: #7f5539;
  font-family: "Courier New", Courier, monospace;
}
.template-archive .repo-card, .template-archive .fact {
  border: 1px solid #e8e2da;
  background: #fdfbf8;
  padding: 24px;
  position: relative;
}
.template-archive .repo-card::before, .template-archive .fact::before {
  content: "";
  position: absolute;
  top: 12px;
  left: 12px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #d6ccc2;
}

</style>
{% endblock %}
