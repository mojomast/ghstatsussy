{% extends "report_base.html.j2" %}

{% block theme_css %}
<style>

/* Fieldnotes Theme */
.template-fieldnotes {
  background: #f4f1ea;
  color: #4a463f;
  background-image: linear-gradient(#e5e0d8 1px, transparent 1px);
  background-size: 100% 28px;
  line-height: 28px;
}
.template-fieldnotes .hero, .template-fieldnotes .panel, .template-fieldnotes .chart-card {
  background: rgba(255,255,255,0.9);
  border: 1px solid #dcd7ce;
  border-radius: 4px;
  box-shadow: 2px 4px 12px rgba(0,0,0,0.05);
}
.template-fieldnotes h1, .template-fieldnotes h2 {
  font-family: "Courier New", Courier, monospace;
  color: #2c2a26;
}
.template-fieldnotes .section-kicker {
  color: #b25c42;
  font-weight: bold;
  text-decoration: underline;
  text-decoration-style: wavy;
}
.template-fieldnotes .repo-card, .template-fieldnotes .fact, .template-fieldnotes .hero-stat {
  border: none;
  border-left: 4px solid #466a62;
  background: rgba(70, 106, 98, 0.05);
  border-radius: 0;
}

</style>
{% endblock %}
