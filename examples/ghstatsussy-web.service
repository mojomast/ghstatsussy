[Unit]
Description=ghstatsussy hosted web app
After=network.target

[Service]
Type=simple
User=mojo
Group=mojo
WorkingDirectory=/home/mojo/projects/locscan
EnvironmentFile=/etc/ghstatsussy.env
ExecStart=/home/mojo/projects/locscan/.venv/bin/ghstats-web
ExecStart=
ExecStart=/home/mojo/projects/locscan/.venv/bin/python -m uvicorn ghstats.web.app:app --host 127.0.0.1 --port 8001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
