[Unit]
Description=ghstatsussy report worker
After=network.target ghstatsussy-web.service

[Service]
Type=simple
User=mojo
Group=mojo
WorkingDirectory=/home/mojo/projects/locscan
EnvironmentFile=/etc/ghstatsussy.env
ExecStart=/home/mojo/projects/locscan/.venv/bin/python -m ghstats.web.worker
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
